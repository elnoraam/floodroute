# FloodRoute environment template
# Copy this to /etc/floodroute.env on the server and set secure values.
DB_HOST=127.0.0.1
DB_PORT=5432
DB_NAME=floodroute
DB_USER=floodroute
DB_PASS=change_me
JWT_SECRET=replace_with_strong_secret
PORT=5500
# Optional: OpenRouteService API key for better routing
ORS_API_KEY=
# Logging level (optional): debug, info, warn, error
LOG_LEVEL=info
# Example: set to true to enable debug logging
# DEBUG=true
